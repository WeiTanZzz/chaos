# Elasticsearch (read-only source)
ES_URL=https://localhost:9200
ES_INDEX_PATTERN=.ds-entities_history_stream_01-*
# Auth: set ES_API_KEY, OR ES_USERNAME + ES_PASSWORD, OR leave all empty for no auth.
ES_API_KEY=
ES_USERNAME=elastic
ES_PASSWORD=
# Staging clusters often use self-signed certs; keep false there.
ES_VERIFY_CERTS=false

# ClickHouse (target) — defaults match ../../install/compose.yaml
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=admin
CLICKHOUSE_PASSWORD=changeme
CLICKHOUSE_DATABASE=default

# Tuning
BATCH_SIZE=5000
ES_PIT_KEEP_ALIVE=2m
